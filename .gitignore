# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# scraper firemního portálu — citlivé: přihlášená relace a stažená data
scripts/scraper/.session.json
scripts/scraper/data/

# typescript
*.tsbuildinfo
next-env.d.ts

# Lokální referenční materiály z firemního portálu (nepatří do gitu)
EDO/
# Drop-folder pro hromadný import metodických PDF (lokální, mimo git)
metodika/

.vercel
